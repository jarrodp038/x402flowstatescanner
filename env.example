# ===========================================
# FlowState AI - x402 Smart Contract Scanner
# ===========================================

# Your wallet address to receive USDC payments (REQUIRED)
# This is where your USDC payments will be sent on Base network
WALLET_ADDRESS=

# Server port
PORT=4021

# Network Configuration (CAIP-2 shorthand)
#   Testing:    base-sepolia
#   Production: base
NETWORK=base-sepolia

# Facilitator URL
#   Testing:    https://x402.org/facilitator
#   Production: https://api.cdp.coinbase.com/platform/v2/x402
FACILITATOR_URL=https://x402.org/facilitator

# CDP API Keys (required for production/CDP facilitator)
# Get these from https://portal.cdp.coinbase.com
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

# Optional: Restrict CORS origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
